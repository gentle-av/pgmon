{
  "server": {
    "port": 3001,
    "ssl": {
      "enabled": true,
      "keyStore": "classpath:keystore.p12",
      "keyStorePassword": "changeit",
      "keyStoreType": "PKCS12",
      "keyAlias": "tomcat"
    }
  },
  "web": {
    "enabled": true,
    "staticPath": "/web",
    "title": "PostgreSQL Monitor",
    "refreshIntervalSeconds": 10,
    "theme": "dark"
  },
  "databases": [
    {
      "name": "avr18",
      "host": "localhost",
      "port": 5432,
      "database": "avr",
      "username": "avr",
      "password": "1",
      "enabled": true,
      "monitoringIntervalSeconds": 30,
      "ssl": {
        "enabled": false,
        "mode": "require",
        "sslCert": "classpath:client-cert.pem",
        "sslKey": "classpath:client-key.pem",
        "sslRootCert": "classpath:ca-cert.pem"
      }
    }
  ],
  "monitoring": {
    "defaultIntervalSeconds": 30,
    "collectQueries": true,
    "collectConnections": true,
    "collectLocks": true,
    "collectCacheHitRatio": true,
    "collectTableSizes": true,
    "slowQueryThresholdMs": 1000,
    "maxSlowQueries": 10
  },
  "alerting": {
    "enabled": true,
    "webhookUrl": "http://localhost:9090/alerts",
    "connectionThresholds": {
      "maxConnections": 100,
      "minAvailableConnections": 5
    },
    "lockThresholdSeconds": 30,
    "cacheHitRatioMinPercent": 95
  }
}
